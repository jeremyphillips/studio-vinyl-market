{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "apps/web/app/**/page.tsx",
    "apps/web/app/**/layout.tsx",
    "apps/web/app/**/not-found.tsx",
    "apps/web/app/**/error.tsx",
    "apps/web/app/**/route.ts",
    "apps/studio/sanity.config.ts"
  ],
  "ignorePatterns": ["**/*.generated.*", "apps/web/**/*.config.{mjs,cjs,js,ts}"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "packages": ["apps/*", "packages/*"]
  },
  "duplicates": {
    "minOccurrences": 2,
    "ignore": [
      "**/*.test.{ts,tsx}",
      "**/*.spec.{ts,tsx}",
      "**/*.test-utils.{ts,tsx}",
      "**/test-utils.{ts,tsx}"
    ]
  },
  "health": {
    "ignore": [
      "**/*.test.{ts,tsx}",
      "**/*.spec.{ts,tsx}",
      "**/*.test-utils.{ts,tsx}",
      "**/test-utils.{ts,tsx}"
    ]
  },
  "rules": {
    "unused-exports": "warn",
    "unused-types": "warn",
    "unused-dependencies": "warn",
    "unused-dev-dependencies": "off",
    "unlisted-dependencies": "warn"
  }
}
