{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "globalPassThroughEnv": ["SANITY_AUTH_TOKEN"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "typegen"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_SANITY_PROJECT_ID",
        "NEXT_PUBLIC_SANITY_DATASET",
        "NEXT_PUBLIC_SANITY_API_VERSION",
        "NEXT_PUBLIC_SANITY_STUDIO_URL",
        "SANITY_API_READ_TOKEN",
        "SANITY_STUDIO_PROJECT_ID",
        "SANITY_STUDIO_DATASET",
        "SANITY_STUDIO_PREVIEW_URL"
      ]
    },
    "typegen": {
      "outputs": ["schema.json", "../web/sanity/types.generated.ts"],
      "inputs": [
        "schemaTypes/**",
        "sanity.config.ts",
        "sanity.cli.ts",
        "sanity.project.ts",
        "../web/sanity/**/*.{ts,tsx}",
        "!../web/sanity/types.generated.ts"
      ]
    },
    "@vinyl-market/web#typegen": {
      "outputs": ["../studio/schema.json", "sanity/types.generated.ts"],
      "inputs": [
        "../studio/schemaTypes/**",
        "../studio/sanity.config.ts",
        "../studio/sanity.cli.ts",
        "../studio/sanity.project.ts",
        "sanity/**/*.{ts,tsx}",
        "!sanity/types.generated.ts"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck", "typegen"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
