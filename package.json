{
  "name": "vinyl-market",
  "private": true,
  "version": "1.0.0",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "typegen": "turbo run typegen",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.5",
    "turbo": "^2.5.0",
    "typescript": "^5.8"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20.11"
  },
  "prettier": {
    "bracketSpacing": false,
    "printWidth": 100,
    "semi": false,
    "singleQuote": true
  }
}
