{
  "name": "@vinyl-market/studio",
  "private": true,
  "version": "1.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "node --env-file=.env node_modules/.bin/sanity build",
    "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "seed:releases-page": "sanity exec ./scripts/seed-releases-page.ts --with-user-token",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .sanity schema.json"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@vinyl-market/release-constants": "*",
    "@sanity/icons": "^3.7.4",
    "@sanity/ui": "^3.2.0",
    "@sanity/vision": "5.28.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "5.28.0",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.2",
    "eslint": "^9.28",
    "jsdom": "^29.1.1",
    "typescript": "^5.8",
    "vitest": "^3.2.4"
  }
}
