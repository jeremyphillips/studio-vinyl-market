# Vinyl Market — env reference.
#
# This file is the single source of truth for the env vars used across the
# monorepo. Each app has its own .env file (gitignored). On first checkout:
#
#   cp .env.example apps/studio/.env
#   cp .env.example apps/web/.env.local
#
# Then trim each copy down to the variables that app actually reads (listed
# below) and replace the placeholder values.
#
# Project / dataset IDs are not secret; tokens ARE secret.

# ─── apps/studio (Sanity Studio) ────────────────────────────────────────────────
# Loaded by `dotenv` in apps/studio/sanity.cli.ts (and exposed to Studio code
# via Vite — Studio code can read these as `process.env.SANITY_STUDIO_*`).

SANITY_STUDIO_PROJECT_ID=1on695jt
SANITY_STUDIO_DATASET=production

# Local dev URL of apps/web — used by the Presentation tool to preview pages.
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000

# Optional: Editor token for `yarn seed:releases-page` in apps/studio (idempotent
# singleton seed). Opening "Releases page" in the desk also applies initialValue.
SANITY_API_WRITE_TOKEN=<your_sanity_editor_token>

# ─── apps/web (Next.js) ────────────────────────────────────────────────────────
# Loaded automatically by Next.js from apps/web/.env.local.

NEXT_PUBLIC_SANITY_PROJECT_ID=1on695jt
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-01

# URL of the deployed (or local) Studio — used to link "edit in studio" from the
# disable-draft-mode helper. Use http://localhost:3333 for local Studio dev.
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# Server-only viewer token with `viewer` role. Required for Live Content API +
# Draft Mode. Create at https://www.sanity.io/manage → API → Tokens.
SANITY_API_READ_TOKEN=<your_sanity_viewer_token>

# Discogs database search — proxied server-side so the token is never bundled
# into the Studio client. Add to apps/web/.env.local (NOT apps/studio/.env).
DISCOGS_API_TOKEN=<your_discogs_api_token>
